{
  "name": "gcpusage",
  "version": "1.0.0",
  "description": "GLM Coding Plan usage monitor CLI tool",
  "type": "module",
  "bin": {
    "gcpusage": "./dist/cli.js"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun && chmod +x dist/cli.js",
    "dev": "bun --watch src/cli.ts"
  },
  "keywords": ["glm", "usage", "monitor", "cli"],
  "license": "MIT",
  "files": ["dist"],
  "dependencies": {
    "cli-table3": "^0.6.5"
  },
  "devDependencies": {
    "bun-types": "^1.3.5",
    "typescript": "^5.9.3"
  }
}
